{
  "name": "pastel-gradient",
  "description": "Lavender/purple, wellness and lifestyle",
  "colors": {
    "background": "#f5f0ff",
    "primary": "#8b5cf6",
    "secondary": "#a78bfa",
    "accent": "#ec4899",
    "text": "#1e1b4b",
    "textMuted": "#6b7280"
  },
  "typography": {
    "display":  { "family": "DM Serif Display", "weight": 400, "size": 128, "lineHeight": 0.95, "tracking": -0.02 },
    "title":    { "family": "DM Serif Display", "weight": 400, "size": 84,  "lineHeight": 1.0,  "tracking": -0.01 },
    "subhead":  { "family": "Inter",            "weight": 500, "size": 48,  "lineHeight": 1.2,  "tracking": 0 },
    "body":     { "family": "Inter",            "weight": 400, "size": 36,  "lineHeight": 1.5,  "tracking": 0 },
    "caption":  { "family": "Inter",            "weight": 500, "size": 28,  "lineHeight": 1.3,  "tracking": 0 },
    "label":    { "family": "Inter",            "weight": 600, "size": 22,  "lineHeight": 1.0,  "tracking": 0.12, "uppercase": true }
  },
  "spacing":  { "xs": 8, "sm": 16, "md": 32, "lg": 60, "xl": 120 },
  "rhythm":   { "bpm": 88,  "beatsPerScene": 8, "transitionBeats": 1.5, "fps": 30 },
  "motion":   { "enterCurve": "out-quart", "exitCurve": "in-quart", "pulseCurve": "back-out", "transitionCurve": "in-out-quart" }
}
