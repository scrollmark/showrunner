{
  "name": "paper-press",
  "description": "Cream + black + red, newspaper editorial",
  "colors": {
    "background": "#f8f4ed",
    "primary": "#111111",
    "secondary": "#404040",
    "accent": "#b91c1c",
    "text": "#0a0a0a",
    "textMuted": "#525252"
  },
  "typography": {
    "display":  { "family": "Playfair Display", "weight": 900, "size": 150, "lineHeight": 0.9,  "tracking": -0.04 },
    "title":    { "family": "Playfair Display", "weight": 800, "size": 92,  "lineHeight": 0.95, "tracking": -0.03 },
    "subhead":  { "family": "Inter",            "weight": 600, "size": 46,  "lineHeight": 1.15, "tracking": -0.01 },
    "body":     { "family": "Inter",            "weight": 400, "size": 36,  "lineHeight": 1.5,  "tracking": 0 },
    "caption":  { "family": "Inter",            "weight": 500, "size": 28,  "lineHeight": 1.3,  "tracking": 0 },
    "label":    { "family": "Inter",            "weight": 700, "size": 22,  "lineHeight": 1.0,  "tracking": 0.18, "uppercase": true }
  },
  "spacing":  { "xs": 8, "sm": 16, "md": 32, "lg": 60, "xl": 120 },
  "rhythm":   { "bpm": 108, "beatsPerScene": 8, "transitionBeats": 1.0, "fps": 30 },
  "motion":   { "enterCurve": "out-cubic", "exitCurve": "in-cubic", "pulseCurve": "back-out", "transitionCurve": "in-out-cubic" },
  "music":    { "moods": ["editorial", "warm", "contemplative"], "volume": 0.18 }
}
